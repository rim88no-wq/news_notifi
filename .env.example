# .env.example — copy this to .env and fill in values
PORT=3000
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# VAPID keys for Web Push notifications.
# Generate once with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k);"
# These MUST stay the same across restarts and deploys — changing them invalidates
# every existing push subscription and users stop receiving notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
